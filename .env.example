# 复制为 .env 并按需修改
# .env 由 dotenvy 自动加载，用于覆盖 config.toml 中的敏感/环境相关配置。

# 日志级别（tracing-subscriber 读取）
RUST_LOG=datasphere=info,rocket=info

# 配置文件路径（默认 config.toml）
# DATASPHERE_CONFIG=config.toml

# 数据库连接串（覆盖 config.toml 中的 database.url）
# 推荐把含密码的连接串放这里，config.toml 保持占位
DATABASE_URL=mysql://root:123456@localhost:3306/datasphere
